{
  "name": "huis-dashboard",
  "version": "0.1.0",
  "description": "Local-network dashboard server with an Ollama-driven agent",
  "main": "src/server.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node src/server.js",
    "validate": "node src/validation/cli.js",
    "redteam": "node src/validation/redteam-cli.js",
    "supervise": "node src/validation/supervised-cli.js",
    "delegate": "node src/validation/delegated-cli.js",
    "parallel": "node src/validation/parallel-cli.js",
    "test": "node --test",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html && npm run lint:json && npm run check-loc",
    "lint:js": "eslint .",
    "lint:css": "stylelint 'public/**/*.css'",
    "lint:html": "htmlhint 'public/**/*.html'",
    "lint:json": "node scripts/check-json.mjs",
    "check-loc": "node scripts/check-loc.mjs",
    "prepare": "git config core.hooksPath .githooks || true",
    "logs": "node src/chatlog-cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^4.22.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "htmlhint": "^1.9.2",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended": "^18.0.0"
  }
}
